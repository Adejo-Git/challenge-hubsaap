{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../../../dist/out-tsc",
    "module": "esnext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "types": ["jest", "node"],
    "emitDecoratorMetadata": false,
    "experimentalDecorators": true,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "files": ["src/test-setup.ts"],
  "include": [
    "jest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
