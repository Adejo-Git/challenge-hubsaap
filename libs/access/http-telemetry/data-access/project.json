{
  "name": "http-telemetry",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "libs/access/http-telemetry/data-access",
  "sourceRoot": "libs/access/http-telemetry/data-access/src",
  "tags": [
    "type:shared",
    "scope:shared"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/http-telemetry",
        "main": "libs/access/http-telemetry/data-access/src/index.ts",
        "tsConfig": "libs/access/http-telemetry/data-access/tsconfig.lib.json"
      },
      "parallelism": true,
      "dependsOn": [
        "^build"
      ]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/access/http-telemetry/data-access/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      },
      "parallelism": true,
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx eslint libs/access/http-telemetry/data-access/src --ext .ts"
      },
      "cache": true
    }
  },
  "implicitDependencies": []
}
