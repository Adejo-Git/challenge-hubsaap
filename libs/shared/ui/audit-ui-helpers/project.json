{
  "name": "audit-ui-helpers",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "libs/shared/ui/audit-ui-helpers",
  "sourceRoot": "libs/shared/ui/audit-ui-helpers/src",
  "prefix": "hub",
  "projectType": "library",
  "tags": ["type:shared", "scope:shared"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/shared/ui/audit-ui-helpers/jest.config.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx eslint libs/shared/ui/audit-ui-helpers/src --ext .ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/shared/ui/audit-ui-helpers/tsconfig.lib.json"
      }
    }
  }
}
