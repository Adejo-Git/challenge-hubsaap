{
  "name": "tool-contract",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/tool/tool-contract/src",
  "prefix": "hub",
  "projectType": "library",
  "tags": ["type:contracts", "scope:tool"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/tool/tool-contract/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/tool/tool-contract/jest.config.js"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx eslint libs/tool/tool-contract/src --ext .ts"
      }
    }
  }
}
