{
  "name": "tool-registry",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "libs/tool/tool-registry",
  "sourceRoot": "libs/tool/tool-registry/src",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/tool-registry",
        "main": "libs/tool/tool-registry/src/index.ts",
        "tsConfig": "libs/tool/tool-registry/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/tool/tool-registry/jest.config.js",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx eslint libs/tool/tool-registry/src --ext .ts"
      }
    }
  },
  "tags": ["type:shared", "scope:shared"]
}
