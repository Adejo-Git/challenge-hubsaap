{
  "extends": ["plugin:@nx/typescript"],
  "plugins": ["@nx"],
  "rules": {
    "@typescript-eslint/adjacent-overload-signatures": "off",
    "@typescript-eslint/ban-ts-comment": "off"
  },
  "ignorePatterns": [],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {
        "@typescript-eslint/adjacent-overload-signatures": "off",
        "@nx/enforce-module-boundaries": [
          "error",
          {
            "allow": ["@hub/access-layer"],
            "enforceBuildableLibDependency": true,
              "depConstraints": [
                { "sourceTag": "type:shell", "onlyDependOnLibsWithTags": ["type:access", "type:shared"] },
                { "sourceTag": "type:tool", "onlyDependOnLibsWithTags": ["type:shared", "type:contracts", "scope:<toolKey>"] },
                { "sourceTag": "type:access", "onlyDependOnLibsWithTags": ["type:domain", "type:contracts", "type:shared"] },
                { "sourceTag": "type:domain", "onlyDependOnLibsWithTags": ["type:contracts", "type:shared"] },
                { "sourceTag": "type:shared", "onlyDependOnLibsWithTags": ["type:shared", "type:contracts"] },
                { "sourceTag": "type:contracts", "onlyDependOnLibsWithTags": ["type:domain", "type:shared", "type:access", "type:tool"] },
                { "sourceTag": "*", "onlyDependOnLibsWithTags": ["*"] }
              ]
          }
        ]
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {}
    },
    {
      "files": ["*.js", "*.jsx"],
      "rules": {}
    }
  ]
}
